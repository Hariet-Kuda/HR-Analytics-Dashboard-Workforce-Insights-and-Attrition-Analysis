model Model
	culture: en-ZA
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-ZA
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["Departments","Education","HR_Data","Jobs"]

annotation PBI_ProTooling = ["DevMode"]

ref table Departments
ref table Education
ref table HR_Data
ref table Jobs

ref role UgandaRole

ref cultureInfo en-ZA

